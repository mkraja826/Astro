APP_ENV=development
PORT=8080
LOG_LEVEL=INFO

# Exact hostnames accepted by TrustedHostMiddleware. Wildcards are rejected.
JYOTHISYAM_ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# Optional exact browser origins. Leave empty for service-to-service deployments.
JYOTHISYAM_CORS_ORIGINS=
# Requests exceeding this byte limit are rejected with HTTP 413.
JYOTHISYAM_MAX_REQUEST_BODY_BYTES=1048576
# End-to-end API request timeout in seconds.
JYOTHISYAM_REQUEST_TIMEOUT_SECONDS=30
# Development defaults to enabled. Production must keep this false.
JYOTHISYAM_ENABLE_DOCS=true

# Local development may leave this false. The production Docker image sets it true.
JYOTHISYAM_REQUIRE_API_KEY=false
# Use an independently generated secret containing at least 32 characters.
JYOTHISYAM_API_KEY=

# Local/test may use memory. Staging and production default to the durable Supabase backend.
JYOTHISYAM_USAGE_BACKEND=memory
JYOTHISYAM_REQUIRE_USAGE_GUARD=false
# Unit-cost request limit. Endpoint-specific billing weights are intentionally not enabled in v1.
JYOTHISYAM_REQUESTS_PER_MINUTE=60
# Zero means meter usage without enforcing a monthly credit ceiling.
JYOTHISYAM_MONTHLY_CREDIT_LIMIT=0
JYOTHISYAM_USAGE_RPC_TIMEOUT_SECONDS=5
# Astro Supabase project only. This exact URL is public configuration, not a secret.
JYOTHISYAM_SUPABASE_URL=https://hdaugtypjpniesdgyral.supabase.co
# Server secret. Never expose this value to the Horos app or commit it to Git.
JYOTHISYAM_SUPABASE_SERVICE_ROLE_KEY=

# Local Skyfield/JPL DE440s kernel. The server never downloads it automatically.
JYOTHISYAM_JPL_EPHEMERIS_PATH=app/data/jpl/de440s.bsp
JYOTHISYAM_JPL_EPHEMERIS_SHA256=c1c7feeab882263fc493a9d5a5b2ddd71b54826cdf65d8d17a76126b260a49f2
