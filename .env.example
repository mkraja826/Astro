APP_ENV=development
PORT=8080
LOG_LEVEL=INFO

# Required before activating a public production service: agpl or professional.
JYOTHISYAM_SWISS_LICENSE_MODE=unset

# Defaults to true when APP_ENV=production and false otherwise.
JYOTHISYAM_REQUIRE_SWISS_EPHEMERIS=false

# Optional override. The default is app/data/ephe inside the project.
JYOTHISYAM_EPHEMERIS_PATH=app/data/ephe
