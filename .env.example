APP_ENV=development
PORT=8080
LOG_LEVEL=INFO

# Required before activating a public Swiss-backed production service: agpl or professional.
JYOTHISYAM_SWISS_LICENSE_MODE=unset

# Defaults to true when APP_ENV=production and false otherwise.
JYOTHISYAM_REQUIRE_SWISS_EPHEMERIS=false

# Optional override. The Swiss default is app/data/ephe inside the project.
JYOTHISYAM_EPHEMERIS_PATH=app/data/ephe

# Local Skyfield/JPL DE440s kernel. The server never downloads it automatically.
JYOTHISYAM_JPL_EPHEMERIS_PATH=app/data/jpl/de440s.bsp
