# Non-secret staging configuration. Secret values are injected by the deployment platform.
APP_ENV=staging
PORT=8080
LOG_LEVEL=INFO

# Replace with the exact staging hostname. Wildcards are rejected.
JYOTHISYAM_ALLOWED_HOSTS=staging-api.example.com
# Leave empty for service-to-service access. Add only exact HTTPS origins when a browser client is approved.
JYOTHISYAM_CORS_ORIGINS=
JYOTHISYAM_MAX_REQUEST_BODY_BYTES=1048576
JYOTHISYAM_REQUEST_TIMEOUT_SECONDS=30
JYOTHISYAM_ENABLE_DOCS=false

JYOTHISYAM_REQUIRE_API_KEY=true
# Secret: inject JYOTHISYAM_API_KEY from the platform secret store.

JYOTHISYAM_USAGE_BACKEND=supabase
JYOTHISYAM_REQUIRE_USAGE_GUARD=true
JYOTHISYAM_REQUESTS_PER_MINUTE=60
JYOTHISYAM_MONTHLY_CREDIT_LIMIT=0
JYOTHISYAM_USAGE_RPC_TIMEOUT_SECONDS=5
JYOTHISYAM_SUPABASE_URL=https://hdaugtypjpniesdgyral.supabase.co
# Secret: inject JYOTHISYAM_SUPABASE_SERVICE_ROLE_KEY from the platform secret store.

JYOTHISYAM_JPL_EPHEMERIS_PATH=/app/app/data/jpl/de440s.bsp
JYOTHISYAM_JPL_EPHEMERIS_SHA256=c1c7feeab882263fc493a9d5a5b2ddd71b54826cdf65d8d17a76126b260a49f2
